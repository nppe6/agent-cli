{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .codex/hooks/shelf-session-start.py",
            "timeout": 15,
            "statusMessage": "Loading Shelf context..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .codex/hooks/shelf-inject-workflow-state.py",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
